<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="MKVOrchestrator.App.Controls.OrchestratorSection">
  <Border Classes="soft-card" Padding="14">
    <DockPanel LastChildFill="True">
      <StackPanel DockPanel.Dock="Top" Spacing="0">
        <TextBlock Text="{Binding Title, RelativeSource={RelativeSource AncestorType=UserControl}}"
                   Classes="section-header" />
        <Border Classes="separator" />
      </StackPanel>
      <ContentPresenter Content="{Binding SectionContent, RelativeSource={RelativeSource AncestorType=UserControl}}" />
    </DockPanel>
  </Border>
</UserControl>
