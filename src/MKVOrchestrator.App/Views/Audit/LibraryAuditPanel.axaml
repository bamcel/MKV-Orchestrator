<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MKVOrchestrator.App.ViewModels"
             xmlns:model="using:MKVOrchestrator.Core.Models"
             x:Class="MKVOrchestrator.App.Views.Audit.LibraryAuditPanel"
             x:DataType="vm:MainWindowViewModel">
  <Grid RowDefinitions="Auto,*,190" RowSpacing="12" Margin="0,12,0,0">
    <Border Classes="card" Grid.Row="0">
      <Grid ColumnDefinitions="120,360,Auto,Auto,Auto,*" ColumnSpacing="10" RowDefinitions="Auto,Auto,Auto" RowSpacing="6">
        <TextBlock Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="6" Text="Library Source" Classes="section-header" />
        <TextBlock Grid.Row="1" Grid.Column="0" Text="Watch folder" VerticalAlignment="Center" Classes="muted" />
          <ComboBox Grid.Row="1" Grid.Column="1"
                  ItemsSource="{Binding LibraryAuditWatchFolderOptions}"
                  SelectedItem="{Binding SelectedLibraryAuditWatchFolder}"
                  MinWidth="320" />
        <Button Grid.Row="1" Grid.Column="2" Content="Refresh" Command="{Binding RefreshLibraryAuditWatchFoldersCommand}" />
        <Button Grid.Row="1" Grid.Column="3" Content="Build Overview" Command="{Binding RunLibraryAuditCommand}" IsEnabled="{Binding !IsLibraryAuditBusy}" />
        <Button Grid.Row="1" Grid.Column="4" Content="Send Selection to Dashboard" Command="{Binding SendSelectedAuditIssuesToDashboardCommand}" IsEnabled="{Binding !IsLibraryAuditBusy}" />
        <Button Grid.Row="1" Grid.Column="5" Content="Cancel" Command="{Binding CancelCommand}" IsEnabled="{Binding IsLibraryAuditBusy}" HorizontalAlignment="Left" />
        <TextBlock Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="6"
                   Text="Builds a cached overview of the selected watch folder. Select a season or folder group to review its media profile, warnings, and files that can be sent into Dashboard for rename, merge, or track-property work."
                   TextWrapping="Wrap" Classes="muted" />
      </Grid>
    </Border>

    <Border Classes="card" Grid.Row="1">
      <DockPanel>
        <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto" ColumnSpacing="8" Margin="0,0,0,8">
          <TextBlock Grid.Column="0" Text="Library Overview" Classes="section-header" />
          <Button Grid.Column="1"
                  Content="{Binding LibraryWarningFilterButtonText}"
                  Command="{Binding ToggleLibraryWarningsOnlyCommand}" />
        </Grid>
        <DataGrid ItemsSource="{Binding DisplayedLibraryAuditItems}"
                  SelectedItem="{Binding SelectedLibraryAuditItem}"
                  AutoGenerateColumns="False"
                  CanUserSortColumns="True"
                  CanUserResizeColumns="True"
                  GridLinesVisibility="Horizontal"
                  Margin="2">
          <DataGrid.Columns>
            <DataGridTemplateColumn Header="status" Width="90" SortMemberPath="Status">
              <DataGridTemplateColumn.CellTemplate>
                <DataTemplate x:DataType="model:LibraryAuditSeasonItem">
                  <TextBlock Text="{Binding Status}" Foreground="{Binding RowVisualState, Converter={StaticResource VisualStateBrushConverter}}" Margin="2,0" />
                </DataTemplate>
              </DataGridTemplateColumn.CellTemplate>
            </DataGridTemplateColumn>
            <DataGridTemplateColumn Header="title" Width="220" SortMemberPath="ShowName">
              <DataGridTemplateColumn.CellTemplate>
                <DataTemplate x:DataType="model:LibraryAuditSeasonItem">
                  <TextBlock Text="{Binding ShowName}" Foreground="{Binding RowVisualState, Converter={StaticResource VisualStateBrushConverter}}" TextTrimming="CharacterEllipsis" ToolTip.Tip="{Binding ShowName}" Margin="2,0" />
                </DataTemplate>
              </DataGridTemplateColumn.CellTemplate>
            </DataGridTemplateColumn>
            <DataGridTemplateColumn Header="season/folder" Width="150" SortMemberPath="SeasonFolder">
              <DataGridTemplateColumn.CellTemplate>
                <DataTemplate x:DataType="model:LibraryAuditSeasonItem">
                  <TextBlock Text="{Binding SeasonFolder}" Foreground="{Binding RowVisualState, Converter={StaticResource VisualStateBrushConverter}}" TextTrimming="CharacterEllipsis" ToolTip.Tip="{Binding SeasonFolder}" Margin="2,0" />
                </DataTemplate>
              </DataGridTemplateColumn.CellTemplate>
            </DataGridTemplateColumn>
            <DataGridTemplateColumn Header="files" Width="70" SortMemberPath="FileCount">
              <DataGridTemplateColumn.CellTemplate>
                <DataTemplate x:DataType="model:LibraryAuditSeasonItem">
                  <TextBlock Text="{Binding FileCount}" Foreground="{Binding RowVisualState, Converter={StaticResource VisualStateBrushConverter}}" Margin="2,0" />
                </DataTemplate>
              </DataGridTemplateColumn.CellTemplate>
            </DataGridTemplateColumn>
            <DataGridTemplateColumn Header="standard video" Width="220" SortMemberPath="StandardVideo">
              <DataGridTemplateColumn.CellTemplate>
                <DataTemplate x:DataType="model:LibraryAuditSeasonItem">
                  <TextBlock Text="{Binding StandardVideo}" Foreground="{Binding RowVisualState, Converter={StaticResource VisualStateBrushConverter}}" TextTrimming="CharacterEllipsis" ToolTip.Tip="{Binding StandardVideo}" Margin="2,0" />
                </DataTemplate>
              </DataGridTemplateColumn.CellTemplate>
            </DataGridTemplateColumn>
            <DataGridTemplateColumn Header="standard audio" Width="260" SortMemberPath="StandardAudio">
              <DataGridTemplateColumn.CellTemplate>
                <DataTemplate x:DataType="model:LibraryAuditSeasonItem">
                  <TextBlock Text="{Binding StandardAudio}" Foreground="{Binding RowVisualState, Converter={StaticResource VisualStateBrushConverter}}" TextTrimming="CharacterEllipsis" ToolTip.Tip="{Binding StandardAudio}" Margin="2,0" />
                </DataTemplate>
              </DataGridTemplateColumn.CellTemplate>
            </DataGridTemplateColumn>
            <DataGridTemplateColumn Header="standard subtitles" Width="260" SortMemberPath="StandardSubtitles">
              <DataGridTemplateColumn.CellTemplate>
                <DataTemplate x:DataType="model:LibraryAuditSeasonItem">
                  <TextBlock Text="{Binding StandardSubtitles}" Foreground="{Binding RowVisualState, Converter={StaticResource VisualStateBrushConverter}}" TextTrimming="CharacterEllipsis" ToolTip.Tip="{Binding StandardSubtitles}" Margin="2,0" />
                </DataTemplate>
              </DataGridTemplateColumn.CellTemplate>
            </DataGridTemplateColumn>
            <DataGridTemplateColumn Header="warnings" Width="*" SortMemberPath="IssueSummary">
              <DataGridTemplateColumn.CellTemplate>
                <DataTemplate x:DataType="model:LibraryAuditSeasonItem">
                  <TextBlock Text="{Binding IssueSummary}" Foreground="{Binding RowVisualState, Converter={StaticResource VisualStateBrushConverter}}" TextTrimming="CharacterEllipsis" ToolTip.Tip="{Binding IssueSummary}" Margin="2,0" />
                </DataTemplate>
              </DataGridTemplateColumn.CellTemplate>
            </DataGridTemplateColumn>
          </DataGrid.Columns>
        </DataGrid>
      </DockPanel>
    </Border>

    <Border Classes="card"
            Grid.Row="2"
            IsVisible="{Binding !IsLibraryAuditSummaryExpanded}">
      <DockPanel>
        <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto" Margin="0,0,0,6">
          <StackPanel Grid.Column="0">
            <TextBlock Text="Selection Details" Classes="section-header" />
            <TextBlock Text="{Binding LibraryAuditDetailSummary}" Classes="muted" TextWrapping="Wrap" />
          </StackPanel>
          <Button Grid.Column="1"
                  Content="Expand"
                  Width="72"
                  Height="28"
                  Padding="8,0"
                  FontSize="12"
                  Command="{Binding ToggleLibraryAuditSummaryExpandedCommand}" />
        </Grid>
        <TextBlock DockPanel.Dock="Bottom" Text="{Binding LibraryAuditStatusText}" TextWrapping="Wrap" Classes="muted" Margin="0,6,0,0" />
        <ListBox ItemsSource="{Binding SelectedLibraryAuditIssueLines}" Classes="console">
          <ListBox.ItemTemplate>
            <DataTemplate x:DataType="model:LibraryAuditIssueLine">
              <TextBlock FontFamily="Consolas" FontSize="12" TextWrapping="Wrap">
                <Run Text="{Binding Prefix}" />
                <Run Text="{Binding Highlight}" Foreground="Orange" />
                <Run Text="{Binding Suffix}" />
              </TextBlock>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
      </DockPanel>
    </Border>

    <Border Grid.Row="0"
            Grid.RowSpan="3"
            Classes="card"
            IsVisible="{Binding IsLibraryAuditSummaryExpanded}">
      <DockPanel>
        <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto" Margin="0,0,0,8">
          <StackPanel Grid.Column="0">
            <TextBlock Text="Selection Details" Classes="section-header" />
            <TextBlock Text="{Binding LibraryAuditDetailSummary}" Classes="muted" TextWrapping="Wrap" />
          </StackPanel>
          <Button Grid.Column="1"
                  Content="Collapse"
                  Width="82"
                  Height="28"
                  Padding="8,0"
                  FontSize="12"
                  Command="{Binding ToggleLibraryAuditSummaryExpandedCommand}" />
        </Grid>
        <TextBlock DockPanel.Dock="Bottom" Text="{Binding LibraryAuditStatusText}" TextWrapping="Wrap" Classes="muted" Margin="0,6,0,0" />
        <ListBox ItemsSource="{Binding SelectedLibraryAuditIssueLines}" Classes="console">
          <ListBox.ItemTemplate>
            <DataTemplate x:DataType="model:LibraryAuditIssueLine">
              <TextBlock FontFamily="Consolas" FontSize="12" TextWrapping="Wrap">
                <Run Text="{Binding Prefix}" />
                <Run Text="{Binding Highlight}" Foreground="Orange" />
                <Run Text="{Binding Suffix}" />
              </TextBlock>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
      </DockPanel>
    </Border>
  </Grid>
</UserControl>
