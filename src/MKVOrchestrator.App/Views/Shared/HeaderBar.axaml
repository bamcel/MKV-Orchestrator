<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MKVOrchestrator.App.ViewModels"
             x:Class="MKVOrchestrator.App.Views.Shared.HeaderBar"
             x:DataType="vm:MainWindowViewModel">
  <Border Classes="card">
    <Grid ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="10" VerticalAlignment="Center">
      <TextBlock Text="MKV Orchestrator" Classes="app-title" />
      <TextBlock Grid.Column="1" Text="Batch metadata, title, language, and remux planning" VerticalAlignment="Center" Classes="muted" />
      <TextBlock Grid.Column="2" Text="{Binding StatusText}" VerticalAlignment="Center" Classes="success" />
      <Button Grid.Column="3" Content="Cancel" Command="{Binding CancelCommand}" IsEnabled="{Binding IsBusy}" />
    </Grid>
  </Border>
</UserControl>
