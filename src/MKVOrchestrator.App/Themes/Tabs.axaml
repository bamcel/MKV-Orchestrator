<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <Style Selector="TabControl">
    <Setter Property="Background" Value="Transparent"/>
  </Style>

  <Style Selector="TabItem">
    <Setter Property="Background" Value="Transparent"/>
    <Setter Property="BorderThickness" Value="0"/>
    <Setter Property="Padding" Value="10,5"/>
    <Setter Property="Margin" Value="2,0,2,0"/>
    <Setter Property="FontSize" Value="19"/>
    <Setter Property="FontWeight" Value="SemiBold"/>
    <Setter Property="Foreground" Value="#8B93A7"/>
  </Style>

  <Style Selector="TabItem:pointerover">
    <Setter Property="Foreground" Value="#F8F8F2" />
  </Style>

  <Style Selector="TabItem:pointerover /template/ ContentPresenter">
    <Setter Property="Foreground" Value="#F8F8F2" />
  </Style>


  <!-- Selected navigation text uses muted Dracula subtitle color -->
  <Style Selector="TabItem:selected">
    <Setter Property="Foreground" Value="#F8F8F2" />
  </Style>

  <Style Selector="TabItem:selected /template/ ContentPresenter">
    <Setter Property="Foreground" Value="#F8F8F2" />
  </Style>



  <!-- Softer styling for Settings subtabs -->
  <Style Selector="TabControl.settings-tabs TabItem">
    <Setter Property="FontSize" Value="15"/>
    <Setter Property="FontWeight" Value="SemiBold"/>
    <Setter Property="Padding" Value="14,4"/>
    <Setter Property="Margin" Value="2,0,2,0"/>
  </Style>

</Styles>
