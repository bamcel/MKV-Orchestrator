<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Style Selector="Window">
    <Setter Property="Background" Value="#1E1F29" />
    <Setter Property="Foreground" Value="#F8F8F2" />
    <Setter Property="FontFamily" Value="Inter, Segoe UI, Arial" />
  </Style>

  <Style Selector="TextBlock">
    <Setter Property="Foreground" Value="#F8F8F2" />
  </Style>
  <Style Selector="TextBlock.app-title">
    <Setter Property="FontSize" Value="24" />
    <Setter Property="FontWeight" Value="Bold" />
    <Setter Property="Foreground" Value="#BD93F9" />
  </Style>

  <Style Selector="TextBlock.muted">
    <Setter Property="Foreground" Value="#CFCFEA" />
  </Style>

  <Style Selector="TextBlock.success">
    <Setter Property="Foreground" Value="#50FA7B" />
  </Style>

  <Style Selector="ProgressBar">
    <Setter Property="Foreground" Value="#50FA7B" />
    <Setter Property="Background" Value="#343746" />
  </Style>

</Styles>
